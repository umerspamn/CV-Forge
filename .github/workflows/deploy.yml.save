name: Deploy CVForge to EC2

on:
  push:
    branches: [ main ]
  workflow_dispatch:

jobs:
  deploy:
    name: Deploy to EC2
    runs-on: ubuntu-latest

    steps:

      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Deploy to EC2 via SSH
        uses: appleboy/ssh-action@v1.0.3
        with:
          host:     ${{ secrets.EC2_HOST }}
          username: ${{ secrets.EC2_USER }}
          key:      ${{ secrets.EC2_SSH_KEY }}
          timeout:  120s
          script: |
            echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
            echo "  CVForge Deployment Started"
            echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

            cd /home/ubuntu/cvforge-docker

            echo "→ Pulling latest code..."
            git pull origin main

            echo "→ Rebuilding containers..."
            docker compose up -d --build

            echo "→ Waiting for containers to be healthy..."
            sleep 20

            echo "→ Checking container status..."
            docker compose ps

            echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
            echo "  ✅ Deployment complete!"
            echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

      - name: Verify site is live
        run: |
          sleep 15
          response=$(curl -s -o /dev/null -w "%{http_code}" https://cvforge.duckdns.org)
          echo "HTTP Status: $response"
          if [ "$response" = "200" ] || [ "$response" = "301" ] || [ "$response" = "302" ]; then
            echo "✅ Site is responding"
          else
            echo "⚠️ Unexpected status $response — check manually"
          fi
